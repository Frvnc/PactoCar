# ============================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env al repositorio.
# ============================================================

PORT=3000

# Credenciales de PostgreSQL
DB_USER=postgres
DB_PASSWORD=TU_CONTRASEÑA_AQUI
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pactocar_db

# Secret para firmar JWT — debe ser una cadena larga y aleatoria.
# Genera una con: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=GENERA_UN_SECRET_SEGURO_AQUI
